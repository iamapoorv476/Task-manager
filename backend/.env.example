# Copy this file to .env and fill in real values.
# Never commit .env — it is gitignored.

# --- App ---
ENVIRONMENT=development

# --- Database ---
# Format: postgresql+psycopg://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/task_manager

# --- Security ---
# Generate with: openssl rand -hex 32
SECRET_KEY=2e1423835466edbed44d1b047110bab070db177c6414936baeb9c66573d8790c
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- CORS ---
# Comma-separated origins allowed to call this API from a browser
CORS_ORIGINS=["http://localhost:5173"]

# --- Redis (optional; app runs fine without it, just skips caching) ---
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=30

# --- Pagination ---
DEFAULT_PAGE_SIZE=10
MAX_PAGE_SIZE=100
